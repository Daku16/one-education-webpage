{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text"
    },
    "content": {
      "type": "blocks"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "resource_type": {
      "type": "enumeration",
      "enum": [
        "actividad",
        "juego",
        "guia",
        "cuento",
        "video"
      ]
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "facil",
        "medio",
        "avanzado"
      ]
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category",
      "mappedBy": "resource"
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag"
    },
    "age_groups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::age-group.age-group",
      "mappedBy": "resource"
    },
    "audience": {
      "type": "enumeration",
      "enum": [
        "nino",
        "docente"
      ]
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "shared.rich-text",
        "resource.callout",
        "resource.key-points",
        "resource.material-list",
        "resource.phase-list",
        "resource.phase-item",
        "resource.activity",
        "resource.links",
        "resource.media-block",
        "resource.document-block"
      ]
    }
  }
}
